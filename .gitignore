# ============================================================
#   THREAT DETECTION HUB - .gitignore
#   Developed by INAMULHASSAN
# ============================================================

# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Logs — keep folder structure, ignore log files
*.log
backend/logs/*
!backend/logs/.gitkeep
logs/*

# Flask session files — keep folder, ignore session data
backend/flask_session/*
!backend/flask_session/.gitkeep

# Trained ML models — large binaries, regenerated by setup.bat
backend/models/*.pkl
!backend/models/.gitkeep

# Database files (user data - not for version control)
backend/data/users.json
backend/data/web_content.json
backend/data/alerts.json
backend/data/data/users.json
backend/data/data/web_content.json
backend/data/data/alerts.json

# Keep training data
!backend/data/data/training_data.csv

# Stray root-level folders created by old path bugs (fixed)
/data/
/logs/

# Environment secrets
backend/config/.env.local
backend/config/.env.production

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/settings.json
.idea/
*.swp
*.swo

# Distribution / packaging
dist/
build/
*.egg-info/

# Coverage reports
htmlcov/
.coverage
