# ============================================================
#   THREAT DETECTION HUB - Environment Configuration Template
#   Copy this file to .env and fill in your values:
#     cp backend/config/.env.example backend/config/.env
# ============================================================

# ── Database (optional — default is JSON files, no setup needed) ──
MONGODB_URI=mongodb://localhost:27017/
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=terrorism_detection

# ── Email Alerts (optional) ───────────────────────────────────────
# Leave blank to disable email alerts.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
ALERT_RECIPIENTS=admin@example.com

# ── Social Media APIs (optional) ─────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# ── System ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALERT_THRESHOLD=0.7
MONITORING_INTERVAL=6
